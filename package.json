{
  "name": "offlinecat-project",
  "version": "0.2.0",
  "private": true,
  "author": "mmurakaru",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:rust": "cd src-tauri && cargo fmt --all -- --check && cargo clippy --lib --no-default-features --all-targets -- -D warnings",
    "lint:rust:fix": "cd src-tauri && cargo fmt --all && cargo clippy --lib --no-default-features --all-targets --fix --allow-dirty --allow-staged",
    "test:rust": "cd src-tauri && cargo test --lib --no-default-features",
    "validate": "npm run lint && npm run typecheck && npx vitest run && npm run lint:rust && npm run test:rust",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/suggestion": "^3.22.3",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.5.10",
    "fflate": "^0.8.2",
    "i18next": "^26.0.4",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.3",
    "react-router": "7.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
