{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "offline.cat",
  "version": "0.2.0",
  "identifier": "cat.offline.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "offline.cat",
        "url": "/create",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first computer-assisted translation tool.",
    "longDescription": "offline.cat is a professional CAT tool that runs entirely on your machine using on-device language models. No accounts, no API keys, no telemetry.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/mmurakaru/offline.cat/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwNDhENkQ4Q0EzMjgzRUYKUldUdmd6TEsyTlpJa09uenpMRDh3RTlObVZIb2djdmdEand5UmR2WDdBQUpMbDN5a2dUKzIvSXYK"
    }
  }
}
